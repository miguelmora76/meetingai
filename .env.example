# =============================================================================
# EngineerAI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.

# Database
DATABASE_URL=postgresql+asyncpg://meetingai:meetingai@db:5432/meetingai

# LLM — Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here
SUMMARIZATION_MODEL=claude-sonnet-4-6
EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Embeddings — local sentence-transformers (no API key required)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Whisper transcription
WHISPER_MODE=local        # "local" (faster-whisper, CPU) or "api" (OpenAI API)
WHISPER_MODEL=base        # tiny | base | small | medium | large  (local mode only)
OPENAI_API_KEY=           # only required when WHISPER_MODE=api

# Admin — protect the /admin/reset endpoint
ADMIN_TOKEN=change-me-before-deploying

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Airtable incident sync (disabled by default)
AIRTABLE_ENABLED=false
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Incidents
APP_BASE_URL=http://localhost:8000

# Fernet key for encrypting user-supplied Airtable PATs at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MUST be stable across restarts — rotating it invalidates all stored tokens.
AIRTABLE_TOKEN_ENCRYPTION_KEY=

# Slack (disabled by default)
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=

# RAG tuning
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# Background task timeout (seconds, default 30 minutes)
PROCESSING_TIMEOUT_SECONDS=1800
